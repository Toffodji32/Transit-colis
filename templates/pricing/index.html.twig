{% extends 'base.html.twig' %}

{% block title %}Tarifs - Transit Colis Nigeria-Bénin{% endblock %}

{% block body %}
    {% include 'components/navbar.html.twig' %}

    <main class="flex-1">
        <!-- Hero Section -->
        <section class="relative w-full py-20 lg:py-32 bg-gradient-to-br from-primary/10 to-primary/5">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h1 class="text-4xl font-black leading-tight tracking-[-0.033em] md:text-6xl mb-4">
                    Tarifs Transparents
                </h1>
                <p class="text-lg font-normal text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
                    Des prix compétitifs pour tous vos envois entre Nigeria et Bénin
                </p>
            </div>
        </section>

        <!-- Tarifs Section -->
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16">
                <!-- Nigeria -> Bénin -->
                <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                    <div class="bg-gradient-to-r from-primary to-blue-600 p-6 text-white">
                        <h2 class="text-2xl font-bold mb-2">Nigeria → Bénin</h2>
                        <p class="text-blue-100">De Lagos vers Cotonou</p>
                    </div>
                    <div class="p-6">
                        {% if tarifsNGB|length > 0 %}
                            <div class="space-y-4">
                                {% for tarif in tarifsNGB %}
                                    <div class="flex justify-between items-center p-4 bg-gray-50 dark:bg-gray-700/30 rounded-lg">
                                        <div>
                                            <p class="font-bold text-gray-900 dark:text-white">
                                                {% if tarif.poidsMin and tarif.poidsMax %}
                                                    {{ tarif.poidsMin }} - {{ tarif.poidsMax }} kg
                                                {% else %}
                                                    Tout poids
                                                {% endif %}
                                            </p>
                                            {% if tarif.description %}
                                                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{{ tarif.description }}</p>
                                            {% endif %}
                                        </div>
                                        <p class="text-2xl font-black text-primary">
                                            {{ tarif.prixParKg }} FCFA/kg
                                        </p>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="text-center py-8">
                                <span class="material-symbols-outlined text-6xl text-gray-300 mb-4">attach_money</span>
                                <p class="text-gray-600 dark:text-gray-400">Tarifs à venir</p>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Bénin -> Nigeria -->
                <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                    <div class="bg-gradient-to-r from-orange-500 to-orange-600 p-6 text-white">
                        <h2 class="text-2xl font-bold mb-2">Bénin → Nigeria</h2>
                        <p class="text-orange-100">De Cotonou vers Lagos</p>
                    </div>
                    <div class="p-6">
                        {% if tarifsBEN|length > 0 %}
                            <div class="space-y-4">
                                {% for tarif in tarifsBEN %}
                                    <div class="flex justify-between items-center p-4 bg-gray-50 dark:bg-gray-700/30 rounded-lg">
                                        <div>
                                            <p class="font-bold text-gray-900 dark:text-white">
                                                {% if tarif.poidsMin and tarif.poidsMax %}
                                                    {{ tarif.poidsMin }} - {{ tarif.poidsMax }} kg
                                                {% else %}
                                                    Tout poids
                                                {% endif %}
                                            </p>
                                            {% if tarif.description %}
                                                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{{ tarif.description }}</p>
                                            {% endif %}
                                        </div>
                                        <p class="text-2xl font-black text-orange-600">
                                            {{ tarif.prixParKg }} FCFA/kg
                                        </p>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="text-center py-8">
                                <span class="material-symbols-outlined text-6xl text-gray-300 mb-4">attach_money</span>
                                <p class="text-gray-600 dark:text-gray-400">Tarifs à venir</p>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Calculateur de prix -->
            <div class="bg-gradient-to-br from-primary/10 to-blue-50 dark:from-gray-800 dark:to-gray-900 rounded-xl p-8 border border-primary/20">
                <h2 class="text-3xl font-bold mb-6 text-center">Calculez le prix de votre envoi</h2>
                <div class="max-w-2xl mx-auto">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-sm font-medium mb-2">Direction</label>
                            <select id="direction" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                                <option value="NG-BN">Nigeria → Bénin</option>
                                <option value="BN-NG">Bénin → Nigeria</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-2">Poids (kg)</label>
                            <input type="number" id="poids" step="0.1" min="0.1" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3" placeholder="ex: 5.5">
                        </div>
                        <div class="flex items-end">
                            <button onclick="calculerPrix()" class="w-full bg-primary text-white rounded-lg p-3 font-bold hover:bg-blue-700 transition-colors">
                                Calculer
                            </button>
                        </div>
                    </div>
                    <div id="resultat" class="mt-6 text-center hidden">
                        <div class="bg-white dark:bg-gray-800 rounded-lg p-6 border-2 border-primary">
                            <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">Prix estimé</p>
                            <p class="text-4xl font-black text-primary" id="prix-resultat">0 FCFA</p>
                            <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">Prix final calculé au pesage</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Avantages -->
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <h2 class="text-3xl font-bold text-center mb-12">Pourquoi nos tarifs ?</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="text-center p-6">
                    <span class="material-symbols-outlined text-primary text-5xl mb-4">price_check</span>
                    <h3 class="font-bold text-lg mb-2">Prix transparents</h3>
                    <p class="text-gray-600 dark:text-gray-400">Aucun frais caché, vous payez uniquement le transport</p>
                </div>
                <div class="text-center p-6">
                    <span class="material-symbols-outlined text-primary text-5xl mb-4">speed</span>
                    <h3 class="font-bold text-lg mb-2">Rapidité</h3>
                    <p class="text-gray-600 dark:text-gray-400">Livraison express en 3-5 jours ouvrés</p>
                </div>
                <div class="text-center p-6">
                    <span class="material-symbols-outlined text-primary text-5xl mb-4">security</span>
                    <h3 class="font-bold text-lg mb-2">Sécurité</h3>
                    <p class="text-gray-600 dark:text-gray-400">Vos colis sont assurés et suivis en temps réel</p>
                </div>
            </div>
        </section>
    </main>

    {% include 'components/footer.html.twig' %}

    <script>
        function calculerPrix() {
            const direction = document.getElementById('direction').value;
            const poids = parseFloat(document.getElementById('poids').value);
            const resultat = document.getElementById('resultat');
            const prixResultat = document.getElementById('prix-resultat');

            if (!poids || poids <= 0) {
                alert('Veuillez entrer un poids valide');
                return;
            }

            // Tarifs approximatifs (à remplacer par les vrais tarifs)
            let prixParKg;
            if (direction === 'NG-BN') {
                prixParKg = 500; // Prix par kg Nigeria → Bénin
            } else {
                prixParKg = 450; // Prix par kg Bénin → Nigeria
            }

            const prixTotal = Math.round(poids * prixParKg);
            prixResultat.textContent = prixTotal.toLocaleString('fr-FR') + ' FCFA';
            resultat.classList.remove('hidden');
        }
    </script>
{% endblock %}
