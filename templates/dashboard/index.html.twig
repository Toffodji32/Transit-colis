{% extends 'base.html.twig' %}

{% block title %}Tableau de Bord - Transit Colis{% endblock %}

{% block body %}
    <header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-gray-200 dark:border-gray-700 bg-white dark:bg-background-dark px-6 sm:px-10 py-3 sticky top-0 z-10">
        <div class="flex items-center gap-4 text-primary">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-2xl">local_shipping</span>
                <h2 class="text-primary dark:text-white text-xl font-bold leading-tight tracking-[-0.015em]">Transit Colis</h2>
            </a>
        </div>
        <div class="flex flex-1 justify-end items-center gap-4 sm:gap-6">
            <form action="{{ path('app_tracking') }}" method="get" class="hidden md:flex flex-col min-w-40 !h-10 max-w-sm">
                <div class="flex w-full flex-1 items-stretch rounded-lg h-full">
                    <div class="text-gray-500 dark:text-gray-400 flex bg-gray-100 dark:bg-gray-700/50 items-center justify-center pl-3 rounded-l-lg border-r-0">
                        <span class="material-symbols-outlined">search</span>
                    </div>
                    <input
                        class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-lg text-[#1F2937] dark:text-white focus:outline-0 focus:ring-2 focus:ring-primary/50 border-none bg-gray-100 dark:bg-gray-700/50 h-full placeholder:text-gray-500 dark:placeholder:text-gray-400 px-4 rounded-l-none border-l-0 pl-2 text-sm font-normal leading-normal"
                        placeholder="Recherche par numéro..." name="numero" value="" />
                </div>
            </form>
            <div class="flex items-center gap-2 sm:gap-4">
                <a href="{{ path('app_colis_new') }}" class="flex min-w-[84px] max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-4 bg-primary text-white text-sm font-bold leading-normal tracking-[0.015em] hover:bg-primary/90 transition-colors">
                    <span class="truncate">Nouvelle Expédition</span>
                </a>
                <button class="flex max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 bg-gray-100 dark:bg-gray-700/50 text-[#1F2937] dark:text-white gap-2 text-sm font-bold leading-normal tracking-[0.015em] min-w-0 px-2.5">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
            </div>
            <div class="flex items-center gap-2">
                {% if app.user %}
                    <span class="text-sm text-gray-600 dark:text-gray-300">{{ app.user.fullName }}</span>
                    <a href="{{ path('app_logout') }}" class="flex max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 bg-gray-100 dark:bg-gray-700/50 text-[#1F2937] dark:text-white gap-2 text-sm font-bold leading-normal tracking-[0.015em] min-w-0 px-2.5 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                        <span class="material-symbols-outlined text-sm">logout</span>
                    </a>
                {% endif %}
            </div>
        </div>
    </header>

    <main class="px-4 sm:px-6 md:px-10 py-8 flex flex-1 justify-center">
        <div class="layout-content-container flex flex-col w-full max-w-7xl flex-1 gap-8">
            <div class="flex flex-wrap justify-between gap-4 items-center">
                <p class="text-[#1F2937] dark:text-white text-4xl font-black leading-tight tracking-[-0.033em] min-w-72">
                    Tableau de Bord
                </p>
            </div>

            {# Statistiques #}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="flex flex-col gap-2 rounded-xl p-6 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">
                    <p class="text-base font-medium leading-normal text-gray-600 dark:text-gray-300">Colis en Transit</p>
                    <p class="text-[#1F2937] dark:text-white tracking-light text-4xl font-bold leading-tight">{{ colisEnTransit }}</p>
                </div>
                <div class="flex flex-col gap-2 rounded-xl p-6 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">
                    <p class="text-base font-medium leading-normal text-gray-600 dark:text-gray-300">Livrés (30 derniers jours)</p>
                    <p class="text-[#1F2937] dark:text-white tracking-light text-4xl font-bold leading-tight">{{ colisLivres30jours }}</p>
                </div>
                <div class="flex flex-col gap-2 rounded-xl p-6 bg-alert/10 dark:bg-alert/20 border border-alert/30">
                    <p class="text-base font-medium leading-normal text-alert">Action Requise</p>
                    <p class="text-alert tracking-light text-4xl font-bold leading-tight">{{ actionRequise }}</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                {# Liste des colis récents #}
                <div class="lg:col-span-2 flex flex-col gap-4">
                    <h2 class="text-[#1F2937] dark:text-white text-[22px] font-bold leading-tight tracking-[-0.015em]">
                        Expéditions Récentes
                    </h2>
                    <div class="@container bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
                        {% if colisRecents|length > 0 %}
                            <div class="overflow-x-auto">
                                <table class="w-full">
                                    <thead>
                                        <tr class="border-b border-gray-200 dark:border-gray-700">
                                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                                                ID de Suivi
                                            </th>
                                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                                                Destination
                                            </th>
                                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                                                Statut
                                            </th>
                                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                                                Date
                                            </th>
                                            <th class="px-6 py-4 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider"></th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                                        {% for coli in colisRecents %}
                                            <tr>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 dark:text-gray-200">
                                                    {{ coli.numeroColis }}
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-300">
                                                    {{ coli.paysDestination }}
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                                    {% set statutColors = {
                                                        'enregistre': 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300',
                                                        'en_preparation': 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300',
                                                        'en_transit': 'bg-in-progress/10 text-in-progress',
                                                        'arrive_destination': 'bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-300',
                                                        'pret_retrait': 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300',
                                                        'livre': 'bg-success/10 text-success',
                                                        'probleme': 'bg-alert/10 text-alert'
                                                    } %}
                                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium {{ statutColors[coli.statutActuel]|default('bg-gray-100 text-gray-800') }}">
                                                        {{ coli.statutActuelLibelle }}
                                                    </span>
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600 dark:text-gray-300">
                                                    {{ coli.dateEnregistrement|date('d M, Y') }}
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                                    <a class="text-primary hover:text-primary/80" href="{{ path('app_tracking', {numero: coli.numeroColis}) }}">Voir Détails</a>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="p-12 text-center">
                                <span class="material-symbols-outlined text-6xl text-gray-300 mb-4">inbox</span>
                                <p class="text-gray-500 dark:text-gray-400 text-lg">Aucune expédition pour le moment</p>
                                <a href="{{ path('app_colis_new') }}" class="mt-4 inline-flex items-center justify-center rounded-lg h-10 px-4 bg-primary text-white text-sm font-bold hover:bg-primary/90 transition-colors">
                                    Créer une expédition
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# Graphique de distribution #}
                <div class="flex flex-col gap-4">
                    <h2 class="text-[#1F2937] dark:text-white text-[22px] font-bold leading-tight tracking-[-0.015em]">
                        Aperçu des Expéditions
                    </h2>
                    <div class="bg-white dark:bg-gray-800 p-6 rounded-xl border border-gray-200 dark:border-gray-700 flex flex-col gap-6">
                        <p class="text-sm text-gray-500 dark:text-gray-400">Distribution des statuts ({{ totalColis }} colis)</p>
                        <div class="flex items-center justify-center">
                            <div class="relative w-48 h-48">
                                <svg class="w-full h-full" viewbox="0 0 36 36">
                                    <circle class="stroke-current text-gray-200 dark:text-gray-600" cx="18" cy="18" fill="none" r="15.9154943092" stroke-width="3"></circle>
                                    <circle class="stroke-current text-success" cx="18" cy="18" fill="none" r="15.9154943092" 
                                        stroke-dasharray="{{ pourcentageLivres }}, 100" stroke-dashoffset="25" stroke-width="3" transform="rotate(-90 18 18)"></circle>
                                    <circle class="stroke-current text-in-progress" cx="18" cy="18" fill="none" r="15.9154943092" 
                                        stroke-dasharray="{{ pourcentageEnTransit }}, 100" stroke-dashoffset="-{{ 25 + pourcentageLivres }}" stroke-width="3" transform="rotate(-90 18 18)"></circle>
                                    <circle class="stroke-current text-alert" cx="18" cy="18" fill="none" r="15.9154943092" 
                                        stroke-dasharray="{{ pourcentageActionRequise }}, 100" stroke-dashoffset="-{{ 25 + pourcentageLivres + pourcentageEnTransit }}" stroke-width="3" transform="rotate(-90 18 18)"></circle>
                                </svg>
                                <div class="absolute inset-0 flex flex-col items-center justify-center">
                                    <span class="text-3xl font-bold text-[#1F2937] dark:text-white">{{ totalColis }}</span>
                                    <span class="text-sm text-gray-500 dark:text-gray-400">Total</span>
                                </div>
                            </div>
                        </div>
                        <div class="flex flex-col gap-3 text-sm">
                            <div class="flex justify-between items-center">
                                <span class="flex items-center gap-2 text-gray-700 dark:text-gray-300"><span class="w-2.5 h-2.5 rounded-full bg-success"></span>Livré</span>
                                <span class="font-medium text-gray-800 dark:text-gray-200">{{ colisLivres30jours }} ({{ pourcentageLivres }}%)</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="flex items-center gap-2 text-gray-700 dark:text-gray-300"><span class="w-2.5 h-2.5 rounded-full bg-in-progress"></span>En Transit</span>
                                <span class="font-medium text-gray-800 dark:text-gray-200">{{ colisEnTransit }} ({{ pourcentageEnTransit }}%)</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="flex items-center gap-2 text-gray-700 dark:text-gray-300"><span class="w-2.5 h-2.5 rounded-full bg-alert"></span>Action Requise</span>
                                <span class="font-medium text-gray-800 dark:text-gray-200">{{ actionRequise }} ({{ pourcentageActionRequise }}%)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    {% include 'components/footer.html.twig' %}
{% endblock %}
