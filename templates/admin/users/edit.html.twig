{% extends 'admin/base.html.twig' %}

{% block title %}Modifier Utilisateur - Admin{% endblock %}

{% block body %}
    <header class="flex items-center justify-between border-b border-solid border-gray-200 dark:border-gray-700 bg-white dark:bg-background-dark px-6 sm:px-10 py-3 sticky top-0 z-50">
        <div class="flex items-center gap-4">
            <a href="{{ path('app_admin_users') }}" class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-2xl">arrow_back</span>
                <h2 class="text-xl font-bold">Modifier Utilisateur</h2>
            </a>
        </div>
    </header>

    <main class="px-6 sm:px-10 py-8 max-w-3xl mx-auto">
        {% for message in app.flashes('error') %}
            <div class="mb-4 p-4 rounded-lg bg-red-100 text-red-800 border border-red-200">
                {{ message }}
            </div>
        {% endfor %}

        <form method="post" class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-8">
            <div class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium mb-2">Nom *</label>
                        <input type="text" name="nom" value="{{ user.nom }}" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Prénom *</label>
                        <input type="text" name="prenom" value="{{ user.prenom }}" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Email</label>
                    <input type="email" value="{{ user.email }}" disabled class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-100 dark:bg-gray-700 p-3 opacity-60">
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Téléphone *</label>
                    <input type="tel" name="telephone" value="{{ user.telephone }}" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Nouveau mot de passe (laisser vide pour conserver)</label>
                    <input type="password" name="password" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Rôles *</label>
                    <div class="space-y-2">
                        <label class="flex items-center">
                            <input type="checkbox" name="roles[]" value="ROLE_USER" {{ 'ROLE_USER' in user.roles ? 'checked' : '' }} class="rounded border-gray-300">
                            <span class="ml-2 text-sm">ROLE_USER</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="roles[]" value="ROLE_ADMIN" {{ 'ROLE_ADMIN' in user.roles ? 'checked' : '' }} class="rounded border-gray-300">
                            <span class="ml-2 text-sm">ROLE_ADMIN</span>
                        </label>
                        <label class="flex items-center">
                            <input type="checkbox" name="roles[]" value="ROLE_ENTREPOT" {{ 'ROLE_ENTREPOT' in user.roles ? 'checked' : '' }} class="rounded border-gray-300">
                            <span class="ml-2 text-sm">ROLE_ENTREPOT</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="flex justify-end gap-4 mt-8">
                <a href="{{ path('app_admin_users') }}" class="px-6 py-3 bg-gray-200 dark:bg-gray-700 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600">
                    Annuler
                </a>
                <button type="submit" class="px-6 py-3 bg-primary text-white rounded-lg hover:bg-blue-700">
                    Enregistrer
                </button>
            </div>
        </form>
    </main>
{% endblock %}

