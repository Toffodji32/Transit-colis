{% extends 'admin/base.html.twig' %}

{% block title %}Gestion Colis - Admin{% endblock %}

{% block body %}
    <header class="flex items-center justify-between border-b border-solid border-gray-200 dark:border-gray-700 bg-white dark:bg-background-dark px-6 sm:px-10 py-3 sticky top-0 z-50">
        <div class="flex items-center gap-4">
            <a href="{{ path('app_admin_dashboard') }}" class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-2xl">arrow_back</span>
                <h2 class="text-xl font-bold">Gestion Colis</h2>
            </a>
        </div>
        <a href="{{ path('app_admin_colis_new') }}" class="flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-700">
            <span class="material-symbols-outlined text-sm">add</span>
            Nouveau Colis
        </a>
    </header>

    <main class="px-6 sm:px-10 py-8 max-w-7xl mx-auto">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-50 dark:bg-gray-700">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Numéro</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Origine → Dest.</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Poids</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                        {% for coli in colis %}
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-mono font-medium text-gray-900 dark:text-white">{{ coli.numeroColis }}</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    {{ coli.paysOrigine }} → {{ coli.paysDestination }}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    {{ coli.poids }} kg
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                        {{ coli.statutActuel|replace({'_': ' '})|capitalize }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    {{ coli.dateEnregistrement|date('d/m/Y') }}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <a href="{{ path('app_colis_show', {id: coli.id}) }}" class="text-primary hover:underline">Voir</a>
                                    <a href="{{ path('app_colis_edit', {id: coli.id}) }}" class="text-green-600 hover:underline ml-3">Éditer</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
{% endblock %}


