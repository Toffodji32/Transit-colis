{% extends 'admin/base.html.twig' %}

{% block title %}Nouveau Colis - Admin{% endblock %}

{% block body %}
    <header class="flex items-center justify-between border-b border-solid border-gray-200 dark:border-gray-700 bg-white dark:bg-background-dark px-6 sm:px-10 py-3 sticky top-0 z-50">
        <div class="flex items-center gap-4">
            <a href="{{ path('app_admin_colis') }}" class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-2xl">arrow_back</span>
                <h2 class="text-xl font-bold">Enregistrer un nouveau colis</h2>
            </a>
        </div>
    </header>

    <main class="px-6 sm:px-10 py-8 max-w-6xl mx-auto">
        {% for message in app.flashes('error') %}
            <div class="mb-4 p-4 rounded-lg bg-red-100 text-red-800 border border-red-200">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="mb-4 p-4 rounded-lg bg-green-100 text-green-800 border border-green-200">
                {{ message }}
            </div>
        {% endfor %}

        <div class="mb-6 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg">
            <div class="flex items-start gap-3">
                <span class="material-symbols-outlined text-green-600 dark:text-green-400 text-2xl">info</span>
                <div>
                    <p class="text-sm font-medium text-green-900 dark:text-green-200 mb-2">
                        Interface d'enregistrement entrepôt
                    </p>
                    <p class="text-xs text-green-700 dark:text-green-300">
                        Remplissez toutes les informations lors du dépôt du colis. Le numéro de suivi sera généré automatiquement si vous ne le renseignez pas.
                    </p>
                </div>
            </div>
        </div>

        <form method="post" class="space-y-8">
            <!-- Informations colis -->
            <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-8">
                <h3 class="text-xl font-bold mb-6">Informations du colis</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <label class="block text-sm font-medium mb-2">Numéro de suivi (optionnel - sera généré si vide)</label>
                        <input type="text" name="numero_colis" placeholder="TC-NG2024-12345" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3 font-mono">
                        <p class="text-xs text-gray-500 mt-1">Laisser vide pour génération automatique</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Poids (kg) *</label>
                        <input type="number" name="poids" step="0.1" min="0.1" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <label class="block text-sm font-medium mb-2">Pays d'origine *</label>
                        <select name="pays_origine" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                            <option value="">Sélectionnez...</option>
                            <option value="Nigeria">Nigeria</option>
                            <option value="Benin">Bénin</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Pays de destination *</label>
                        <select name="pays_destination" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                            <option value="">Sélectionnez...</option>
                            <option value="Nigeria">Nigeria</option>
                            <option value="Benin">Bénin</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Description du contenu</label>
                    <textarea name="description" rows="3" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3"></textarea>
                </div>
            </div>

            <!-- Informations expéditeur -->
            <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-8">
                <h3 class="text-xl font-bold mb-6">Informations expéditeur</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <label class="block text-sm font-medium mb-2">Nom complet *</label>
                        <input type="text" name="expediteur_nom" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Téléphone *</label>
                        <input type="tel" name="expediteur_tel" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Email</label>
                    <input type="email" name="expediteur_email" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                </div>
            </div>

            <!-- Informations destinataire -->
            <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-8">
                <h3 class="text-xl font-bold mb-6">Informations destinataire</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div>
                        <label class="block text-sm font-medium mb-2">Nom complet *</label>
                        <input type="text" name="destinataire_nom" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Téléphone *</label>
                        <input type="tel" name="destinataire_tel" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                    </div>
                </div>

                <div class="mb-6">
                    <label class="block text-sm font-medium mb-2">Email *</label>
                    <input type="email" name="destinataire_email" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                </div>

                <div>
                    <label class="block text-sm font-medium mb-2">Adresse complète</label>
                    <textarea name="destinataire_adresse" rows="2" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3"></textarea>
                </div>
            </div>

            <div class="flex justify-end gap-4">
                <a href="{{ path('app_admin_colis') }}" class="px-6 py-3 bg-gray-200 dark:bg-gray-700 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600">
                    Annuler
                </a>
                <button type="submit" class="px-6 py-3 bg-primary text-white rounded-lg hover:bg-blue-700">
                    Enregistrer le colis
                </button>
            </div>
        </form>
    </main>
{% endblock %}


