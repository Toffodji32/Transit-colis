{% extends 'entrepot/base.html.twig' %}

{% block title %}Colis - {{ warehouse.nom }} - Transit Colis{% endblock %}

{% block page_title %}Colis - {{ warehouse.nom }}{% endblock %}

{% block entrepot_content %}
    {% for message in app.flashes('success') %}
        <div class="mb-4 p-4 rounded-lg bg-green-100 text-green-800 border border-green-200">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="mb-4 p-4 rounded-lg bg-red-100 text-red-800 border border-red-200">
            {{ message }}
        </div>
    {% endfor %}

    <div class="flex justify-end mb-6">
        <a href="{{ path('app_entrepot_colis_new') }}" class="flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-700 shadow-sm">
            <span class="material-symbols-outlined text-sm">add</span>
            Nouveau Colis
        </a>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Numéro</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Origine → Dest.</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Poids</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                    {% for coli in colis %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-mono font-medium text-gray-900 dark:text-white">{{ coli.numeroColis }}</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                {{ coli.paysOrigine }} → {{ coli.paysDestination }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                {{ coli.poids }} kg
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                    {{ coli.statutActuel|replace({'_': ' '})|capitalize }}
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                {{ coli.dateEnregistrement|date('d/m/Y') }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                <a href="{{ path('app_colis_show', {id: coli.id}) }}" class="text-primary hover:underline">Voir</a>
                                <button onclick="openStatusModal({{ coli.id }}, '{{ coli.numeroColis }}', '{{ coli.statutActuel }}')" class="ml-3 text-green-600 hover:underline">Changer statut</button>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal changement statut -->
    <div id="statusModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50 flex items-center justify-center">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl max-w-md w-full mx-4">
            <div class="p-6">
                <h3 class="text-xl font-bold mb-4">Changer le statut du colis</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">Numéro : <span id="modalNumero" class="font-mono font-bold"></span></p>
                
                <form id="statusForm" method="post">
                    <div class="mb-4">
                        <label class="block text-sm font-medium mb-2">Nouveau statut *</label>
                        <select name="statut" required id="statutSelect" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                            <option value="">Sélectionnez...</option>
                            <option value="en_preparation">En préparation</option>
                            <option value="en_transit">En transit</option>
                            <option value="arrive_destination">Arrivé à destination</option>
                            <option value="pret_retrait">Prêt pour retrait</option>
                            <option value="livre">Livré</option>
                            <option value="dommage">Dommage</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium mb-2">Commentaire (optionnel)</label>
                        <textarea name="commentaire" rows="3" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3" placeholder="Ajoutez un commentaire..."></textarea>
                    </div>

                    <div class="flex justify-end gap-3">
                        <button type="button" onclick="closeStatusModal()" class="px-4 py-2 bg-gray-200 dark:bg-gray-700 rounded-lg hover:bg-gray-300 dark:hover:bg-gray-600">
                            Annuler
                        </button>
                        <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg hover:bg-blue-700">
                            Confirmer
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        let currentColisId = null;

        function openStatusModal(colisId, numero, currentStatus) {
            currentColisId = colisId;
            document.getElementById('modalNumero').textContent = numero;
            document.getElementById('statusForm').action = '{{ path('app_entrepot_colis_update_status', {id: 0}) }}'.replace('0', colisId);
            document.getElementById('statusModal').classList.remove('hidden');
        }

        function closeStatusModal() {
            document.getElementById('statusModal').classList.add('hidden');
            document.getElementById('statusForm').reset();
        }

        // Fermer avec Échap
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeStatusModal();
            }
        });

        // Fermer en cliquant en dehors
        document.getElementById('statusModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeStatusModal();
            }
        });
    </script>
{% endblock %}

