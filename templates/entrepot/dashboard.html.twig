{% extends 'entrepot/base.html.twig' %}

{% block title %}Dashboard Entrepos - {{ warehouse.nom }} - Transit Colis{% endblock %}

{% block page_title %}Dashboard - {{ warehouse.nom }}{% endblock %}

{% block entrepot_content %}
    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
        <div class="mb-4 p-4 rounded-lg bg-green-100 text-green-800 border border-green-200">
            {{ message }}
        </div>
    {% endfor %}

    <!-- Informations entrepôt -->
    <div class="mb-6 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
        <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-blue-600 dark:text-blue-400 text-3xl">store</span>
            <div>
                <h3 class="text-lg font-bold text-blue-900 dark:text-blue-200">{{ warehouse.nom }}</h3>
                <p class="text-sm text-blue-700 dark:text-blue-300 mt-1">{{ warehouse.pays }} - {{ warehouse.ville }}</p>
                <p class="text-xs text-blue-600 dark:text-blue-400 mt-2">{{ warehouse.adresse }}</p>
            </div>
        </div>
    </div>

    <!-- Statistiques générales -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Total Colis</p>
                    <p class="text-3xl font-black text-gray-900 dark:text-white">{{ totalColis }}</p>
                </div>
                <span class="material-symbols-outlined text-4xl text-blue-500">inventory_2</span>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Colis envoyés</p>
                    <p class="text-3xl font-black text-gray-900 dark:text-white">{{ totalOrigine }}</p>
                </div>
                <span class="material-symbols-outlined text-4xl text-green-500">local_shipping</span>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Colis reçus</p>
                    <p class="text-3xl font-black text-gray-900 dark:text-white">{{ totalDestination }}</p>
                </div>
                <span class="material-symbols-outlined text-4xl text-orange-500">download_done</span>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">En transit</p>
                    <p class="text-3xl font-black text-gray-900 dark:text-white">{{ statutsOrigine.en_transit + statutsDestination.en_transit }}</p>
                </div>
                <span class="material-symbols-outlined text-4xl text-purple-500">flight</span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
        <!-- Répartition par statut - Origine -->
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm">
            <h3 class="text-lg font-bold mb-6">Colis envoyés</h3>
            <div class="space-y-4">
                {% for statut, count in statutsOrigine %}
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-600 dark:text-gray-400 capitalize">{{ statut|replace({'_': ' '}) }}</span>
                        <span class="text-lg font-bold text-gray-900 dark:text-white">{{ count }}</span>
                    </div>
                {% endfor %}
            </div>
        </div>

        <!-- Répartition par statut - Destination -->
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm">
            <h3 class="text-lg font-bold mb-6">Colis reçus</h3>
            <div class="space-y-4">
                {% for statut, count in statutsDestination %}
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-600 dark:text-gray-400 capitalize">{{ statut|replace({'_': ' '}) }}</span>
                        <span class="text-lg font-bold text-gray-900 dark:text-white">{{ count }}</span>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- Colis récents -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-bold">Colis récents</h3>
            <a href="{{ path('app_entrepot_colis') }}" class="text-sm text-primary hover:underline">Voir tout</a>
        </div>
        {% if colisRecents|length > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left py-2 px-4 text-sm font-bold">Numéro</th>
                            <th class="text-left py-2 px-4 text-sm font-bold">Origine → Dest.</th>
                            <th class="text-left py-2 px-4 text-sm font-bold">Statut</th>
                            <th class="text-left py-2 px-4 text-sm font-bold">Date</th>
                            <th class="text-left py-2 px-4 text-sm font-bold">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for coli in colisRecents %}
                            <tr class="border-b border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="py-2 px-4 text-sm font-mono">{{ coli.numeroColis }}</td>
                                <td class="py-2 px-4 text-sm">{{ coli.paysOrigine }} → {{ coli.paysDestination }}</td>
                                <td class="py-2 px-4">
                                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                        {{ coli.statutActuel|replace({'_': ' '})|capitalize }}
                                    </span>
                                </td>
                                <td class="py-2 px-4 text-sm text-gray-600 dark:text-gray-400">{{ coli.dateEnregistrement|date('d/m/Y') }}</td>
                                <td class="py-2 px-4">
                                    <a href="{{ path('app_colis_show', {id: coli.id}) }}" class="text-primary hover:underline text-sm">Voir</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <p class="text-center py-8 text-gray-500">Aucun colis enregistré</p>
        {% endif %}
    </div>
{% endblock %}

