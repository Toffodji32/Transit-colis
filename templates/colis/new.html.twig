{% extends 'base.html.twig' %}

{% block title %}Nouvelle Expédition - Transit Colis{% endblock %}

{% block body %}
    <header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-gray-200 dark:border-gray-800 px-6 sm:px-10 lg:px-20 py-3 bg-white dark:bg-background-dark sticky top-0 z-50">
        <div class="flex items-center gap-4 text-gray-900 dark:text-white">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-2xl">local_shipping</span>
                <h2 class="text-lg font-bold tracking-tight">Transit Colis</h2>
            </a>
        </div>
        <nav class="hidden md:flex flex-1 justify-center items-center gap-8">
            <a class="text-gray-900 dark:text-gray-200 text-sm font-medium hover:text-primary transition-colors" href="{{ path('app_dashboard') }}">Dashboard</a>
            <a class="text-primary text-sm font-semibold" href="{{ path('app_colis_new') }}">Nouvelle Expédition</a>
        </nav>
        <div class="flex items-center gap-4">
            <a href="{{ path('app_dashboard') }}" class="flex items-center gap-2">
                <span class="text-sm text-gray-600 dark:text-gray-300">{{ app.user.fullName }}</span>
            </a>
        </div>
    </header>

    <main class="flex flex-1 justify-center py-8 px-4 sm:px-6 lg:px-8">
        <div class="w-full max-w-4xl">
            <div class="mb-8">
                <h1 class="text-gray-900 dark:text-white text-4xl font-black tracking-tighter">Créer une expédition</h1>
                <p class="text-gray-600 dark:text-gray-400 mt-2">Utilisez le numéro reçu par email ou créez une nouvelle expédition</p>
            </div>

            <!-- Flash Messages -->
            {% for message in app.flashes('error') %}
                <div class="mb-4 p-4 rounded-lg bg-red-100 text-red-800 border border-red-200">
                    {{ message }}
                </div>
            {% endfor %}

            <!-- ÉTAPE 1: Saisir le numéro -->
            <div class="bg-white dark:bg-gray-900/50 p-8 rounded-xl shadow-sm">
                <div class="mb-6 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
                    <div class="flex items-start gap-3">
                        <span class="material-symbols-outlined text-blue-600 dark:text-blue-400 text-2xl">info</span>
                        <div>
                            <p class="text-sm font-medium text-blue-900 dark:text-blue-200 mb-2">
                                Numéro de suivi de l'entrepôt
                            </p>
                            <p class="text-xs text-blue-700 dark:text-blue-300">
                                Entrez le numéro que vous avez reçu par email après l'enregistrement du colis par votre entrepôt
                            </p>
                        </div>
                    </div>
                </div>

                <form method="post">
                    <div class="mb-6">
                        <label class="block text-gray-900 dark:text-white text-sm font-medium mb-2">Numéro de suivi reçu par email</label>
                        <input type="text" name="numero_colis" {% if numero_search is defined %}value="{{ numero_search }}"{% endif %}
                            placeholder="ex: TC-2025-690508A5" 
                            class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-4 text-gray-900 dark:text-white font-mono text-lg" />
                    </div>

                    <div class="flex gap-4">
                        <button type="submit" class="flex-1 px-6 py-3 bg-primary text-white rounded-lg hover:bg-blue-700 font-semibold">
                            Créer l'expédition
                        </button>
                    </div>
                </form>

                <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
                    <p class="text-center text-sm text-gray-600 dark:text-gray-400">
                        Ou <a href="{{ path('app_colis_new_manual') }}" class="text-primary hover:underline font-medium">créer une expédition manuellement</a>
                    </p>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
