{% extends 'base.html.twig' %}

{% block title %}Modifier Colis {{ colis.numeroColis }} - Transit Colis{% endblock %}

{% block body %}
    <header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-gray-200 dark:border-gray-700 bg-white dark:bg-background-dark px-6 sm:px-10 py-3 sticky top-0 z-10">
        <div class="flex items-center gap-4 text-primary">
            <a href="{{ path('app_home') }}" class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-2xl">local_shipping</span>
                <h2 class="text-primary dark:text-white text-xl font-bold">Transit Colis</h2>
            </a>
        </div>
        <div class="flex items-center gap-4">
            <a href="{{ path('app_dashboard') }}" class="text-sm text-gray-600 dark:text-gray-300 hover:text-primary">Retour</a>
        </div>
    </header>

    <main class="px-4 sm:px-6 md:px-10 py-8">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-3xl font-black mb-8">Mettre à jour le statut - {{ colis.numeroColis }}</h1>

            {% for message in app.flashes('success') %}
                <div class="mb-4 p-4 rounded-lg bg-green-100 text-green-800 border border-green-200">
                    {{ message }}
                </div>
            {% endfor %}

            <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-8 mb-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                    <div>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">De</p>
                        <p class="font-medium">{{ colis.paysOrigine }}</p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Vers</p>
                        <p class="font-medium">{{ colis.paysDestination }}</p>
                    </div>
                    <div>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Statut actuel</p>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                            {{ colis.statutActuelLibelle }}
                        </span>
                    </div>
                    <div>
                        <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Poids</p>
                        <p class="font-medium">{{ colis.poids }} kg</p>
                    </div>
                </div>

                <form method="post">
                    <div class="mb-6">
                        <label class="block text-sm font-medium mb-2">Nouveau statut *</label>
                        <select name="statut" required class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3">
                            {% for key, libelle in statuts %}
                                <option value="{{ key }}" {{ colis.statutActuel == key ? 'selected' : '' }}>{{ libelle }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-6">
                        <label class="block text-sm font-medium mb-2">Commentaire</label>
                        <textarea name="commentaire" rows="3" placeholder="Ajoutez un commentaire (optionnel)" class="w-full rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 p-3"></textarea>
                    </div>
                    <div class="flex justify-end gap-4">
                        <a href="{{ path('app_dashboard') }}" class="flex items-center justify-center rounded-lg h-12 px-6 bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-white text-sm font-bold hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors">
                            Annuler
                        </a>
                        <button type="submit" class="flex items-center justify-center rounded-lg h-12 px-6 bg-primary text-white text-sm font-bold hover:bg-blue-700 transition-colors">
                            Enregistrer le changement
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
{% endblock %}

